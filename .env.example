# OpenAI API key for summarization and blog post generation
OPENAI_API_KEY=sk-your-key-here

# Optional: override default model (gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Database URL (SQLite by default)
DATABASE_URL=sqlite:///./data/meeting_minutes.db

# Laserfiche WebLink source (borough assembly)
WEBLINK_BASE_URL=https://kgb-lf-weblink.kgbak.us/WebLink
WEBLINK_REPO_NAME=KGBPUBLIC
WEBLINK_FOLDER_ID=37030
ENABLE_KGB_ASSEMBLY=true

# Ketchikan City Council agendas page
CITY_AGENDA_URL=https://www.ketchikan.gov/council-agendas-and-meetings
CITY_PRIMEGOV_URL=https://ketchikan.primegov.com
CITY_MIN_YEAR=2012
ENABLE_CITY_COUNCIL=true
CITY_SCRAPE_AGENDA_PAGE=true
CITY_USE_PRIMEGOV=true

# How often to run the scraper when using --schedule (hours)
SCRAPE_INTERVAL_HOURS=24

# Default command when the container starts without CLI args (run, schedule, status, list)
BOT_COMMAND=run

# Optional: process only the first N meetings per run (useful for testing)
# PROCESS_LIMIT=1
